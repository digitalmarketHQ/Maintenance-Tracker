rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidMaintenanceRecord(data) {
      return data.date is string && data.date.size() <= 50
        && data.department is string && data.department.size() <= 100
        && data.subject is string && data.subject.size() <= 200
        && data.details is string && data.details.size() <= 1000
        && data.whoDidIt is string && data.whoDidIt.size() <= 100
        && data.cost is number && data.cost >= 0
        && data.createdAt is string && data.createdAt.size() <= 50;
    }

    match /maintenance_records/{recordId} {
      allow read: if true;
      allow create: if isValidId(recordId) && isValidMaintenanceRecord(incoming());
      allow update: if isValidId(recordId) && isValidMaintenanceRecord(incoming());
      allow delete: if true;
    }
  }
}
